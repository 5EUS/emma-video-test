# Copy to .signing.env and source it before packaging.
export EMMA_PLUGIN_REPOSITORY_ID="emma-test"
export EMMA_PLUGIN_SIGNING_KEY_ID="emma-test-shared-release-2026-q2"

# Point this to your local emma-test-repo key file.
# Example: /home/you/Git/emma-test-repo/.keys/emma-test-shared-release-2026-q2.private.pem
export EMMA_PLUGIN_SIGNING_PRIVATE_KEY_BASE64="$(base64 -w 0 /absolute/path/to/emma-test-shared-release-2026-q2.private.pem)"
