<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="dotnet-experimental" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-experimental/nuget/v3/index.json" />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="dotnet-experimental">
      <package pattern="BytecodeAlliance.Componentize.DotNet.Wasm.SDK" />
      <package pattern="Microsoft.DotNet.*" />
      <package pattern="runtime.linux-x64.Microsoft.DotNet.ILCompiler.LLVM" />
      <package pattern="runtime.wasi-wasm.*" />
    </packageSource>
    <packageSource key="nuget">
      <package pattern="BytecodeAlliance.Componentize.DotNet.Wasm.SDK" />
      <package pattern="EMMA.*" />
      <package pattern="Grpc.*" />
      <package pattern="Google.*" />
      <package pattern="Microsoft.*" />
      <package pattern="System.*" />
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
