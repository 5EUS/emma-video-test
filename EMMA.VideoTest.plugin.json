{
  "id": "emma.video.test",
  "name": "EMMA Video Test Plugin",
  "version": "0.1.8",
  "description": "Deterministic video test plugin for stream list and segment retrieval validation.",
  "author": "projectemma",
  "protocol": "grpc",
  "runtime": {
    "minHostVersion": "1.0.0"
  },
  "mediaTypes": [
    "video"
  ],
  "thumbnail": {
    "aspectRatio": 0.7,
    "fit": "cover",
    "width": 256,
    "height": 384
  },
  "searchExperience": {
    "capabilities": [
      "landing-v1",
      "query-additions-v1"
    ],
    "landing": {
      "template": "media-search",
      "title": "Video Test Scenarios",
      "subtitle": "Validate stream discovery, selection, and segment retrieval.",
      "sections": [
        {
          "id": "hero",
          "type": "hero",
          "title": "EMMA Video Test",
          "description": "Each query maps to a deterministic scenario fixture.",
          "mediaTypes": [
            "video"
          ],
          "actions": [
            {
              "id": "quick-single",
              "label": "Single Stream",
              "type": "set-query",
              "value": "single"
            },
            {
              "id": "quick-multi",
              "label": "Multi Stream",
              "type": "set-query",
              "value": "multi"
            },
            {
              "id": "quick-segment",
              "label": "Segment Mode",
              "type": "set-query",
              "value": "segment"
            },
            {
              "id": "quick-empty",
              "label": "Empty Streams",
              "type": "set-query",
              "value": "empty"
            }
          ]
        }
      ]
    },
    "query": {
      "allowFreeText": true,
      "minLength": 0,
      "maxLength": 200,
      "additions": [
        {
          "id": "scenario.hint",
          "label": "Scenario Hint",
          "type": "single",
          "defaultValue": "all",
          "options": [
            {
              "value": "all",
              "label": "All Fixtures",
              "isDefault": true
            },
            {
              "value": "single",
              "label": "Single Stream"
            },
            {
              "value": "multi",
              "label": "Multi Stream"
            },
            {
              "value": "segment",
              "label": "Segment Mode"
            },
            {
              "value": "empty",
              "label": "Empty Streams"
            }
          ],
          "appliesToMediaTypes": [
            "video"
          ]
        }
      ]
    }
  },
  "capabilities": {
    "network": [],
    "fileSystem": [],
    "cache": false,
    "cpuBudgetMs": 250,
    "memoryMb": 512
  },
  "permissions": {
    "domains": [],
    "paths": []
  }
}
