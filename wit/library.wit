package emma:plugin;

interface host-bridge {
  operation-payload: func(operation: string, args-json: option<string>) -> option<string>;
  search-payload: func(query: string) -> option<string>;
  chapters-payload: func(media-id: string) -> option<string>;
  page-payload: func(media-id: string, chapter-id: string, page-index: u32) -> option<string>;
  pages-payload: func(media-id: string, chapter-id: string, start-index: u32, count: u32) -> option<string>;
}

interface plugin {
  record key-value {
    key: string,
    value: string,
  }

  record capability {
    name: string,
    media-types: list<string>,
    operations: list<string>,
  }

  record handshake-response {
    version: string,
    message: string,
  }

  record media-search-item {
    id: string,
    source: string,
    title: string,
    media-type: string,
    thumbnail-url: option<string>,
    description: option<string>,
    metadata: list<key-value>,
  }

  record chapter-item {
    id: string,
    number: u32,
    title: string,
    uploader-groups: list<string>,
  }

  record page-item {
    id: string,
    index: u32,
    content-uri: string,
  }

  record video-stream-item {
    id: string,
    label: string,
    playlist-uri: string,
  }

  record video-segment-item {
    content-type: string,
    payload: list<u8>,
  }

  record media-operation-request {
    operation: string,
    media-id: option<string>,
    media-type: option<string>,
    args-json: option<string>,
    payload-json: option<string>,
  }

  record media-operation-response {
    content-type: string,
    payload-json: string,
  }

  variant operation-error {
    unsupported-operation(string),
    invalid-arguments(string),
    failed(string),
  }

  handshake: func() -> handshake-response;
  capabilities: func() -> list<capability>;

  search: func(query: string, payload-json: string) -> list<media-search-item>;

  chapters: func(media-id: string, payload-json: string) -> list<chapter-item>;
  page: func(media-id: string, chapter-id: string, page-index: u32, payload-json: string) -> option<page-item>;
  pages: func(media-id: string, chapter-id: string, start-index: u32, count: u32, payload-json: string) -> list<page-item>;
  video-streams: func(media-id: string, payload-json: string) -> list<video-stream-item>;
  video-segment: func(media-id: string, stream-id: string, sequence: u32, payload-json: string) -> option<video-segment-item>;

  invoke: func(request: media-operation-request) -> result<media-operation-response, operation-error>;
}

world library {
  import host-bridge;
  export plugin;
}
